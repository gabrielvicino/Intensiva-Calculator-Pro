'sofa_d1'      # 1º slot da janela deslizante (int, padrão 0 = vazio)
'sofa_d2'      # 2º slot
'sofa_d3'      # 3º slot
'sofa_d4'      # 4º slot (mais recente)
'pps'          # Palliative Performance Scale (string, ex: "80%")
'mrs'          # Modified Rankin Scale — selectbox: "0"–"6"
